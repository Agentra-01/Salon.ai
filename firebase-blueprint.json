{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "booking": {
      "title": "Hair Appointment Booking",
      "description": "Client hair and beauty treatment booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["userId", "name", "phone", "email", "service", "date", "time", "createdAt", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "Collection of user profile records"
    },
    "bookings/{bookingId}": {
      "schema": "booking",
      "description": "Collection of appointment bookings"
    }
  }
}
